{
  "name": "@route-auditor/cli",
  "version": "0.3.0",
  "description": "Security auditor for Next.js routes — App Router, Pages Router, API Routes",
  "keywords": [
    "nextjs",
    "security",
    "audit",
    "cli"
  ],
  "license": "MIT",
  "bin": {
    "route-auditor": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest",
    "test:coverage": "vitest --coverage",
    "typecheck": "tsc --noEmit",
    "clean": "rm -rf dist",
    "release": "pnpm build && npm publish --access public"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.3.0",
    "boxen": "latest",
    "chalk": "latest",
    "commander": "latest",
    "glob": "latest",
    "ora": "latest",
    "zod": "latest"
  },
  "devDependencies": {
    "@route-auditor/shared": "workspace:*",
    "@types/node": "latest",
    "@vitest/coverage-v8": "latest",
    "tsup": "latest",
    "typescript": "latest",
    "vitest": "latest"
  }
}
